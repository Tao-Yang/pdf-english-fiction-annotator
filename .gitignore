# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
*.spec

# Downloaded dictionary (large, fetched on demand)
data/ecdict.csv
data/*.7z

# Generated output
output/
*-annotated*.pdf
*.annotations.json

# NLTK data cache
nltk_data/

# Local build/test caches and ad-hoc script artifacts (screenshots, logs,
# downloaded test fixtures) - never meant to be committed.
.cache/
render_*.txt
render_*.png
scripts/_resume_downloads/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
